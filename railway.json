{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "frontend": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "apps/frontend/Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10,
        "startCommand": "node apps/frontend/server.js"
      }
    },
    "backend": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "backend/Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10,
        "startCommand": "uv run gunicorn api:app -w 4 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:8000 --timeout 75"
      }
    }
  }
}
